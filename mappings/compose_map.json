{
  "_comment": "Jetpack Compose 组件 → ArkUI 组件映射",

  "composables": {
    "Text":                    "Text",
    "Button":                  "Button",
    "OutlinedButton":          "Button",
    "TextButton":              "Button",
    "IconButton":              "Button",
    "FilledTonalButton":       "Button",
    "ElevatedButton":          "Button",
    "Column":                  "Column",
    "Row":                     "Row",
    "Box":                     "Stack",
    "Surface":                 "Column",
    "Card":                    "Column",
    "ElevatedCard":            "Column",
    "OutlinedCard":            "Column",
    "Image":                   "Image",
    "Icon":                    "Image",
    "Spacer":                  "Blank",
    "Divider":                 "Divider",
    "HorizontalDivider":       "Divider",
    "VerticalDivider":         "Divider",
    "LazyColumn":              "List",
    "LazyRow":                 "List",
    "LazyVerticalGrid":        "Grid",
    "LazyHorizontalGrid":      "Grid",
    "TextField":               "TextInput",
    "OutlinedTextField":       "TextInput",
    "BasicTextField":          "TextInput",
    "SearchBar":               "Search",
    "Checkbox":                "Checkbox",
    "Switch":                  "Toggle",
    "RadioButton":             "Radio",
    "Slider":                  "Slider",
    "CircularProgressIndicator": "LoadingProgress",
    "LinearProgressIndicator": "Progress",
    "TopAppBar":               "Row",
    "CenterAlignedTopAppBar":  "Row",
    "Scaffold":                "Column",
    "BottomNavigation":        "TabBar",
    "NavigationBar":           "TabBar",
    "NavigationRail":          "SideBarContainer",
    "ModalBottomSheet":        "Panel",
    "AlertDialog":             "AlertDialog",
    "Dialog":                  "CustomDialog",
    "DropdownMenu":            "Menu",
    "ExposedDropdownMenuBox":  "Select",
    "FloatingActionButton":    "Button",
    "ExtendedFloatingActionButton": "Button",
    "Badge":                   "Badge",
    "BadgedBox":               "Badge",
    "Chip":                    "Button",
    "FilterChip":              "Button",
    "InputChip":               "Button",
    "AssistChip":              "Button",
    "SuggestionChip":          "Button",
    "Tab":                     "TabContent",
    "TabRow":                  "Tabs",
    "ScrollableTabRow":        "Tabs",
    "HorizontalPager":         "Swiper",
    "VerticalPager":           "Swiper",
    "AnimatedVisibility":      "if",
    "Crossfade":               "if",
    "Canvas":                  "Canvas"
  },

  "modifiers": {
    "fillMaxWidth":            ".width('100%')",
    "fillMaxHeight":           ".height('100%')",
    "fillMaxSize":             ".width('100%').height('100%')",
    "wrapContentWidth":        "",
    "wrapContentHeight":       "",
    "wrapContentSize":         "",
    "padding":                 ".padding(${args})",
    "paddingValues":           ".padding(${args})",
    "background":              ".backgroundColor(${args})",
    "clip":                    ".borderRadius(${args})",
    "border":                  ".border(${args})",
    "shadow":                  ".shadow(${args})",
    "alpha":                   ".opacity(${args})",
    "rotate":                  ".rotate({ angle: ${args} })",
    "scale":                   ".scale({ x: ${args}, y: ${args} })",
    "offset":                  ".offset({ x: ${x}, y: ${y} })",
    "size":                    ".width(${args}).height(${args})",
    "width":                   ".width(${args})",
    "height":                  ".height(${args})",
    "weight":                  ".layoutWeight(${args})",
    "align":                   ".align(${args})",
    "clickable":               ".onClick(() => { ${args} })",
    "combinedClickable":       ".onClick(() => { ${args} })",
    "selectable":              ".onClick(() => { ${args} })",
    "toggleable":              ".onClick(() => { ${args} })",
    "horizontalScroll":        "",
    "verticalScroll":          "",
    "scrollable":              "",
    "nestedScroll":            "",
    "semantics":               "",
    "testTag":                 "",
    "zIndex":                  ".zIndex(${args})",
    "aspectRatio":             ".aspectRatio(${args})",
    "defaultMinSize":          "",
    "requiredWidth":           ".width(${args})",
    "requiredHeight":          ".height(${args})",
    "requiredSize":            ".width(${args}).height(${args})",
    "indication":              "",
    "focusable":               "",
    "focused":                 ""
  },

  "color_map": {
    "Color.Red":               "#FF0000",
    "Color.Green":             "#00FF00",
    "Color.Blue":              "#0000FF",
    "Color.White":             "#FFFFFF",
    "Color.Black":             "#000000",
    "Color.Gray":              "#888888",
    "Color.Grey":              "#888888",
    "Color.Yellow":            "#FFFF00",
    "Color.Cyan":              "#00FFFF",
    "Color.Magenta":           "#FF00FF",
    "Color.Transparent":       "#00000000",
    "Color.Unspecified":       "Color.Transparent",
    "MaterialTheme.colorScheme.primary": "$r('app.color.primary')",
    "MaterialTheme.colorScheme.secondary": "$r('app.color.secondary')",
    "MaterialTheme.colorScheme.background": "$r('app.color.background')",
    "MaterialTheme.colorScheme.surface": "$r('app.color.surface')",
    "MaterialTheme.colorScheme.onPrimary": "$r('app.color.on_primary')",
    "MaterialTheme.colorScheme.onSurface": "$r('app.color.on_surface')",
    "MaterialTheme.typography.bodyLarge": "{ fontSize: 16 }",
    "MaterialTheme.typography.bodyMedium": "{ fontSize: 14 }",
    "MaterialTheme.typography.bodySmall": "{ fontSize: 12 }",
    "MaterialTheme.typography.titleLarge": "{ fontSize: 22 }",
    "MaterialTheme.typography.titleMedium": "{ fontSize: 16 }",
    "MaterialTheme.typography.titleSmall": "{ fontSize: 14 }",
    "MaterialTheme.typography.headlineLarge": "{ fontSize: 32 }",
    "MaterialTheme.typography.headlineMedium": "{ fontSize: 28 }",
    "MaterialTheme.typography.labelLarge": "{ fontSize: 14 }",
    "MaterialTheme.typography.labelMedium": "{ fontSize: 12 }"
  }
}
